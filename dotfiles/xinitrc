#!/bin/sh

# Polkit (para reboot, poweroff, etc)
# /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Desactivar beep
xset -b

# Fondo de pantalla
feh --bg-scale ~/dev/suckless-btw/background.png &

# Hotkey para cambio de idioma
setxkbmap -layout us,es -option 'grp:alt_shift_toggle'

#slstatus
slstatus &

# Compositor (OBLIGATORIO para alpha)
picom &

#dunst
dunst &

# Window manager (SIEMPRE último)
exec dwm
